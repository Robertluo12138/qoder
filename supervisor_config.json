{
  "version": 2,
  "project_type": "python",
  "test_preset": "pytest",
  "test_command": "python -m pytest -q",
  "test_presets": {
    "pytest": [
      "python",
      "-m",
      "pytest",
      "-q"
    ],
    "ruff_pytest": [
      "bash",
      "-lc",
      "ruff check . && python -m pytest -q"
    ],
    "mypy_pytest": [
      "bash",
      "-lc",
      "mypy . && python -m pytest -q"
    ],
    "ruff_mypy_pytest": [
      "bash",
      "-lc",
      "ruff check . && mypy . && python -m pytest -q"
    ]
  },
  "ignore_paths": [
    "__pycache__",
    "*.pyc",
    "*.pyo",
    ".venv",
    "venv",
    "artifacts",
    ".qoder/state",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    "node_modules",
    ".DS_Store"
  ],
  "allow_dirty_repo": false,
  "prefer_repo_venv": true,
  "allowed_write_roots": [
    ".qoder",
    "docs",
    "scripts",
    "src",
    "tests"
  ],
  "qoder_cli": "qodercli",
  "qoder_headless_args": [
    "-w",
    "{workspace}",
    "-p",
    "{prompt}",
    "--output-format=json",
    "-q"
  ],
  "qoder_timeout_seconds": 1800,
  "qoder_plan_max_turns": 12,
  "qoder_write_max_turns": 40,
  "qoder_review_max_turns": 16,
  "qoder_write_allowed_tools": [
    "Bash",
    "Edit"
  ],
  "qoder_write_disallowed_tools": [],
  "qoder_write_try_without_yolo_first": true,
  "qoder_write_no_yolo_timeout_seconds": 45,
  "qoder_write_yolo": true,
  "qoder_write_yolo_fallback_on_permission_error": true,
  "guardrail_max_request_chars": 1200,
  "guardrail_max_planned_tasks": 3,
  "guardrail_max_changed_files": 8,
  "guardrail_broad_request_markers": [
    "entire repo",
    "whole repo",
    "across the codebase",
    "across the repository",
    "large refactor",
    "full migration",
    "rewrite the project",
    "rewrite the codebase",
    "all files"
  ],
  "single_task_threshold_chars": 200
}
